{
  "name": "webfund",
  "version": "0.1.0",
  "private": true,
  "description": "基金模拟投资助手 - 模拟持仓、实时估值、策略回测",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter @fund/core build && pnpm --filter @fund/web build",
    "build:core": "pnpm --filter @fund/core build",
    "dev:web": "pnpm --filter @fund/web dev",
    "dev:workers": "pnpm --filter @fund/workers dev",
    "test": "pnpm -r test",
    "test:core": "pnpm --filter @fund/core test",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.5.0"
}
